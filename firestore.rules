rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Cards subcollection
      match /cards/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Categories subcollection
      match /categories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Places subcollection
      match /places/{placeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Expenses subcollection
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Recurring expenses subcollection
      match /recurring/{recurringId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Salaries subcollection
      match /salaries/{salaryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Month closings subcollection (immutable — no update/delete allowed)
      match /monthClosings/{closingId} {
        allow read, create: if request.auth != null && request.auth.uid == uid;
      }

      // Product categories — per-user, full CRUD (soft delete via active flag)
      match /productCategories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // User's product copies — per-user, full CRUD (soft delete via active flag)
      match /products/{productId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Notifications subcollection — user receives and manages their own notifications
      match /notifications/{notifId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Report attachments — documents/photos linked to a monthly report
      match /reportAttachments/{attachmentId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Month analysis — AI-generated spending analysis per closed month
      match /monthAnalysis/{yearMonth} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

    }

    // Global places pool — shared community data
    // Any authenticated user can read or create; nobody can update/delete
    match /places/{placeId} {
      allow read, create: if request.auth != null;
    }

    // Global product pool — shared community data
    // Any authenticated user can read, create, or update (for denormalized lastPrice fields)
    // No delete allowed
    match /products/{productId} {
      allow read, create, update: if request.auth != null;
    }

    // Price history — shared community data (keyed by global productId)
    // Any authenticated user can read or create; no delete
    match /priceHistory/{recordId} {
      allow read, create: if request.auth != null;
    }

    // Brands — shared community data
    match /brands/{brandId} {
      allow read, create, update: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
