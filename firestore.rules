rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Cards subcollection
      match /cards/{cardId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Categories subcollection
      match /categories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Places subcollection
      match /places/{placeId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Expenses subcollection
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Recurring expenses subcollection
      match /recurring/{recurringId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Salaries subcollection
      match /salaries/{salaryId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Month closings subcollection (immutable — no update/delete allowed)
      match /monthClosings/{closingId} {
        allow read, create: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Global places pool — shared community data
    // Any authenticated user can read or create; nobody can update/delete
    match /places/{placeId} {
      allow read, create: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
